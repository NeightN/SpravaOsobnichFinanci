<Window x:Class="SpravaOsobnichFinanci.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpravaOsobnichFinanci"
        xmlns:viewmodels="clr-namespace:SpravaOsobnichFinanci.ViewModels"
        xmlns:views="clr-namespace:SpravaOsobnichFinanci.Views"
        mc:Ignorable="d"
        Title="Správa osobních financí" 
        Height="600" Width="900"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <!-- Definice šablon pro propojení ViewModelů s Views -->
    <Window.Resources>
        <!-- Šablona pro Dashboard -->
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <!-- Šablona pro Seznam transakcí -->
        <DataTemplate DataType="{x:Type viewmodels:TransactionListViewModel}">
            <views:TransactionListView />
        </DataTemplate>

        <!-- Šablona pro Editor transakcí -->
        <DataTemplate DataType="{x:Type viewmodels:TransactionEditorViewModel}">
            <views:TransactionEditorView />
        </DataTemplate>

        <!-- Šablona pro Seznam kategorií -->
        <DataTemplate DataType="{x:Type viewmodels:CategoryListViewModel}">
            <views:CategoryListView />
        </DataTemplate>

        <!-- Šablona pro Editor kategorií -->
        <DataTemplate DataType="{x:Type viewmodels:CategoryEditorViewModel}">
            <views:CategoryEditorView />
        </DataTemplate>

        <!-- Šablona pro Nastavení -->
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Styl pro navigační tlačítka s ikonami -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="200"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Kruhové pozadí pro hover a aktivní stav -->
                            <Ellipse x:Name="BgEllipse" Fill="{TemplateBinding Background}" Width="46" Height="46"/>
                            <TextBlock Text="{TemplateBinding Content}" 
                                       FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                                       FontSize="26" 
                                       Foreground="{TemplateBinding Foreground}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="#8B0000"/> <!-- Tmavší červená pro hover -->
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="#660000"/> <!-- Ještě tmavší při kliknutí -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Hlavní rozvržení okna: 2 sloupce (Menu a Obsah) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Levý sloupec pro menu (zúženo na 70 pro ikony) -->
            <ColumnDefinition Width="70"/>
            <!-- Pravý sloupec pro hlavní obsah (zbytek místa) -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEVÝ PANEL: Navigační menu -->
        <Border Grid.Column="0" Background="#B71C1C"> <!-- Červené pozadí -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- Horní část zabere veškerý volný prostor -->
                    <RowDefinition Height="Auto"/>
                    <!-- Spodní část se přizpůsobí velikosti tlačítka -->
                </Grid.RowDefinitions>

                <!-- Horní část: Navigační tlačítka -->
                <StackPanel Grid.Row="0" Margin="0,20,0,0">
                    <!-- Přehled (Monitor s rozložením) -->
                    <Button Content="&#xF0A07;" ToolTip="Přehled" Command="{Binding NavigateToDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentViewName}" Value="Dashboard">
                                        <Setter Property="Background" Value="#8B0000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Transakce (Seznam) -->
                    <Button Content="&#xF1B7B;" ToolTip="Transakce" Command="{Binding NavigateToTransactionsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentViewName}" Value="Transactions">
                                        <Setter Property="Background" Value="#8B0000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Kategorie (Tvary) -->
                    <Button Content="&#xF0495;" ToolTip="Kategorie" Command="{Binding NavigateToCategoriesCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentViewName}" Value="Categories">
                                        <Setter Property="Background" Value="#8B0000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Nastavení (Ozubené kolo) -->
                    <Button Content="&#xF0493;" ToolTip="Nastavení" Command="{Binding NavigateToSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentViewName}" Value="Settings">
                                        <Setter Property="Background" Value="#8B0000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Spodní část: Tlačítko pro ukončení aplikace (Power ikona) -->
                <Button Grid.Row="1" Content="&#xF0425;" ToolTip="Ukončit aplikaci" Command="{Binding ExitApplicationCommand}" Style="{StaticResource NavButtonStyle}" Margin="0,0,0,20"/>
            </Grid>
        </Border>

        <!-- PRAVÝ PANEL: Hlavní obsah -->
        <Border Grid.Column="1" Background="#F5F5F5" Padding="20">
            <!-- 
                 ContentControl slouží jako "kontejner" pro aktuální pohled.
                 Jeho obsah je navázán (Binding) na vlastnost CurrentViewModel v MainViewModelu.
                 WPF automaticky najde správný DataTemplate z Window.Resources a vykreslí ho.
            -->
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>