<UserControl x:Class="SpravaOsobnichFinanci.Views.CategoryListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpravaOsobnichFinanci.Views"
             xmlns:viewmodels="clr-namespace:SpravaOsobnichFinanci.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:CategoryListViewModel}">

    <!-- DEFINICE STYLŮ (Lokální resources platné pouze pro tento UserControl) -->
    <UserControl.Resources>
        <!-- Globální přeprodej vzhledu pro všechna tlačítka v tomto pohledu (přidání zaoblených rohů a efektu při najetí myší) -->
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Oblast pro hlavičku -->
            <RowDefinition Height="Auto"/>
            <!-- Oblast pro DataGrid zabírající zbytek prostoru -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hlavička a tlačítko Přidání nové kategorie -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Správa kategorií" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>

            <!-- Zelené tlačítko s ikonou + a tooltipem pro lepší User Experience -->
            <Button Command="{Binding AddCategoryCommand}" ToolTip="Nová kategorie"
                    HorizontalAlignment="Right" Width="35" Height="35" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand">
                <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                           Text="&#xF0415;" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Tabulka s kategoriemi obalená v šedém Borderu pro hezčí designový rámeček -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White">
            <Grid>
                <!-- Důležitý architektonický prvek: Obal (Mask), díky kterému se nativní ostrý WPF DataGrid 'ořízne' a zachová zaoblené rohy Borderu -->
                <Border x:Name="Mask" Background="White" CornerRadius="7"/>
                
                <DataGrid ItemsSource="{Binding Categories}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" Background="Transparent" BorderBrush="Transparent"
                          GridLinesVisibility="None" RowHeight="45" CanUserResizeRows="False" 
                          HeadersVisibility="Column" BorderThickness="0" FocusVisualStyle="{x:Null}">
                    
                    <!-- Aplikace masky podle Borderu definovaného výše -->
                    <DataGrid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=Mask}"/>
                    </DataGrid.OpacityMask>
                    
                    <!-- Úprava vzhledu samotné tabulky (odstranění výchozích modrých selekcí a ošklivých ohraničení čar) -->
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,10,10,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <!-- Potlačení modrého podbarvení při výběru buňky -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <!-- Styl na úrovni řádku (Row) tabulky -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                                <!-- Jemné zvýraznění celého řádku při přejetí myší (Hover efekt) -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F9F9F9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    
                    <!-- Definice samotných sloupců a obsahu buněk -->
                    <DataGrid.Columns>

                        <!-- Sloupec pro grafické zobrazení ikony v zaobleném kruhu -->
                        <DataGridTemplateColumn Header="Ikona" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- Geometrický trik - CornerRadius roven polovině Width a Height vytvoří dokonalý kruh -->
                                    <Border Width="30" Height="30" CornerRadius="15" 
                                            Background="{Binding ColorHex}" 
                                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">

                                        <!-- Bindovaná ikona se převede Hexadecimální kód z databáze a interpretuje zvoleným Material fontem -->
                                        <TextBlock Text="{Binding IconKey, Converter={StaticResource IconConverter}}" 
                                                   FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                                                   FontSize="16" Foreground="White" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Název" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Akční sloupec s tlačítky pro daný záznam -->
                        <DataGridTemplateColumn Header="" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                                        
                                        <!-- RelativeSource AncestorType=UserControl je zde nezbytné! Tlačítko se totiž normálně nachází 
                                             v kontextu modelu 'Category', ale metoda na editaci Command sídlí ve vrchním 'CategoryListViewModel'. -->
                                        <Button Command="{Binding DataContext.EditCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" ToolTip="Upravit"
                                                Background="#FFC107" Foreground="White" BorderThickness="0" 
                                                Width="32" Height="32" Margin="0,0,5,0" Cursor="Hand">
                                            <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                                                       Text="&#xF03EB;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>

                                        <Button Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" ToolTip="Smazat"
                                                Background="#F44336" Foreground="White" BorderThickness="0" 
                                                Width="32" Height="32" Cursor="Hand">
                                            <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                                                       Text="&#xF01B4;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>