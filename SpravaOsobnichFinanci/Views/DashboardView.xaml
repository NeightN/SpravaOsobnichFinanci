<UserControl x:Class="SpravaOsobnichFinanci.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpravaOsobnichFinanci.Views"
             xmlns:viewmodels="clr-namespace:SpravaOsobnichFinanci.ViewModels"
             xmlns:converters="clr-namespace:SpravaOsobnichFinanci.Converters" 
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=viewmodels:DashboardViewModel}"
             UseLayoutRounding="True" 
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Přepsání designu popisku u grafu (OxyPlot Tracker). Zajišťuje ostré renderování a hezčí stín. -->
        <ControlTemplate x:Key="NoLinesTrackerTemplate">
            <Canvas>
                <Border Canvas.Left="{Binding Position.X}" Canvas.Top="{Binding Position.Y}" 
                        Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Margin="10,10,0,0" Padding="8"
                        UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="5" ShadowDepth="2"/>
                    </Border.Effect>
                    <TextBlock Text="{Binding Text}" Foreground="Black" FontSize="12" TextOptions.TextFormattingMode="Display"/>
                </Border>
            </Canvas>
        </ControlTemplate>

        <!-- Dynamické vrstvení (Z-index). Bez tohoto kódu se vizuálně ořezávaly Tooltipy u grafů pod sousedními prvky -->
        <Style x:Key="WidgetBorderStyle" TargetType="Border">
            <Setter Property="Panel.ZIndex" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. SEKCE | Hlavička a Volba měsíce (Filtrování Dashboardu) -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Přehled financí" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>

                <!-- Filtr aktuálního měsíce (Navigační panel) -->
                <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Padding="5,2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">

                        <!-- Tlačítko Předchozí -->
                        <Button Command="{Binding PreviousMonthCommand}" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Předchozí měsíc">
                            <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0141;" FontSize="20" Foreground="#555555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.Template>
                                <!-- Potlačení zaobleného template z usercontrol, uděláme ho kulatý na hover -->
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="15" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Zobrazení právě vybraného měsíce -->
                        <TextBlock Text="{Binding SelectedMonthText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0" MinWidth="100" TextAlignment="Center"/>

                        <!-- Tlačítko Následující -->
                        <Button Command="{Binding NextMonthCommand}" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Následující měsíc">
                            <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0142;" FontSize="20" Foreground="#555555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="15" Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 2. SEKCE | Pevné rychlé přehledové (KPI) karty -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="-10,0,-10,10">
                <!-- KPI Karta 1: Celkový globální Zůstatek aplikace -->
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Aktuální zůstatek" FontSize="16" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TotalBalance, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
                    </StackPanel>
                </Border>

                <!-- KPI Karta 2: Měsíční (filtrované) výdaje -->
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Měsíční výdaje" FontSize="16" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding MonthlyExpense, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>

                <!-- KPI Karta 3: Měsíční (filtrované) příjmy -->
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Měsíční příjmy" FontSize="16" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding MonthlyIncome, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold" Foreground="#388E3C"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 3. SEKCE | Dynamicky viditelné/skryté grafické widgety -->
            <!-- Použití UniformGridu zaručuje plynulé poskládání 2 oken do řady s tím, že prázdné chybějící/skryté panely ihned zaplní panel následující -->
            <UniformGrid Grid.Row="2" Columns="2" VerticalAlignment="Top" Margin="-10">

                <!-- WIDGET 1: Historie zůstatku na účtu (Line chart) -->
                <Border Style="{StaticResource WidgetBorderStyle}" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10" Height="280"
                        Visibility="{Binding IsBalanceVisible, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Nadpis a ovládací prvek pro skrytí widgetu z obrazovky -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Vývoj zůstatku" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" ToolTip="Skrýt widget" Command="{Binding HideWidgetCommand}" CommandParameter="Balance" Cursor="Hand">
                                    <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0156;" FontSize="18" Foreground="#757575"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E0E0E0" Margin="0,0,0,0"/>

                        <StackPanel Grid.Row="1" Margin="0,10,0,10">
                            <TextBlock Text="Zůstatek" FontSize="12" Foreground="#555555"/>
                            <TextBlock Text="{Binding EndOfMonthBalance, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Vlastní vizualizátor (OxyPlot) vázaný na PlotModel ve ViewModelu. Přijímá na míru napsaný Controller pro snazší hover -->
                        <oxy:PlotView Grid.Row="2" Model="{Binding BalanceChartModel}" Controller="{Binding LineChartController}" DefaultTrackerTemplate="{StaticResource NoLinesTrackerTemplate}" Background="Transparent"/>
                    </Grid>
                </Border>

                <!-- WIDGET 2: Peněžní tok (Progress Bar ukázka) -->
                <Border Style="{StaticResource WidgetBorderStyle}" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10" Height="280"
                        Visibility="{Binding IsCashFlowVisible, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Peněžní tok" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" ToolTip="Skrýt widget" Command="{Binding HideWidgetCommand}" CommandParameter="CashFlow" Cursor="Hand">
                                    <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0156;" FontSize="18" Foreground="#757575"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E0E0E0" Margin="0,0,0,0"/>

                        <StackPanel Grid.Row="1" Margin="0,10,0,10">
                            <TextBlock Text="Daný měsíc" FontSize="12" Foreground="#555555"/>
                            <TextBlock Text="{Binding MonthlyBalance, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" VerticalAlignment="Center">
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="Příjmy" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding MonthlyIncome, Converter={StaticResource CurrencyConverter}}" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <!-- Obalení nativního ProgressBaru Borderem (ClipToBounds) za účelem hezkého vizuálního zakulacení výplně -->
                            <Border CornerRadius="4" Height="20" Background="#EEEEEE" Margin="0,0,0,20" ClipToBounds="True">
                                <ProgressBar Value="{Binding MonthlyIncome}" Maximum="{Binding MaxCashFlow}" Height="20" Foreground="#4CAF50" Background="Transparent" BorderThickness="0"/>
                            </Border>

                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="Výdaje" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding MonthlyExpense, Converter={StaticResource CurrencyConverter}}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border CornerRadius="4" Height="20" Background="#EEEEEE" ClipToBounds="True">
                                <ProgressBar Value="{Binding MonthlyExpense}" Maximum="{Binding MaxCashFlow}" Height="20" Foreground="#F44336" Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- WIDGET 3: Rozpad příjmů do koláčového grafu -->
                <Border Style="{StaticResource WidgetBorderStyle}" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10" Height="280"
                        Visibility="{Binding IsIncomeVisible, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Příjmy za období" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" ToolTip="Skrýt widget" Command="{Binding HideWidgetCommand}" CommandParameter="Income" Cursor="Hand">
                                    <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0156;" FontSize="18" Foreground="#757575"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E0E0E0" Margin="0,0,0,0"/>

                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <!-- Legenda si vezme co zbyde, graf má garantovanou fixní minimální šířku -->
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="160"/>
                            </Grid.ColumnDefinitions>

                            <!-- Custom Legenda grafu vázaná do ItemsControlu, aby se mohla vygenerovat dynamicky pro libovolný počet kategorií -->
                            <ItemsControl Grid.Column="0" ItemsSource="{Binding IncomeLegend}" VerticalAlignment="Center" Margin="0,0,10,0" ClipToBounds="True">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Vertical" MaxHeight="190" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,10,5" Width="95">
                                            <TextBlock Text="{Binding PercentageText}" VerticalAlignment="Center" Width="40" TextAlignment="Right" Margin="0,0,5,0" FontSize="14"/>
                                            <Border Width="40" Height="40" CornerRadius="20" Background="{Binding ColorHex}" 
                                                    ToolTip="{Binding CategoryName}" ToolTipService.InitialShowDelay="0">
                                                <TextBlock Text="{Binding Icon, Converter={StaticResource IconConverter}}" FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <oxy:PlotView Grid.Column="1" Model="{Binding IncomeChartModel}" Controller="{Binding HoverController}" DefaultTrackerTemplate="{StaticResource NoLinesTrackerTemplate}" Background="Transparent"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- WIDGET 4: Rozpad výdajů do koáčového grafu -->
                <Border Style="{StaticResource WidgetBorderStyle}" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10" Height="280"
                        Visibility="{Binding IsExpenseVisible, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Výdaje za období" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" ToolTip="Skrýt widget" Command="{Binding HideWidgetCommand}" CommandParameter="Expense" Cursor="Hand">
                                    <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0156;" FontSize="18" Foreground="#757575"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#E0E0E0" Margin="0,0,0,0"/>

                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="160"/>
                            </Grid.ColumnDefinitions>

                            <ItemsControl Grid.Column="0" ItemsSource="{Binding ExpenseLegend}" VerticalAlignment="Center" Margin="0,0,10,0" ClipToBounds="True">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Vertical" MaxHeight="190" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,10,5" Width="95">
                                            <TextBlock Text="{Binding PercentageText}" VerticalAlignment="Center" Width="40" TextAlignment="Right" Margin="0,0,5,0" FontSize="14"/>
                                            <Border Width="40" Height="40" CornerRadius="20" Background="{Binding ColorHex}" 
                                                    ToolTip="{Binding CategoryName}" ToolTipService.InitialShowDelay="0">
                                                <TextBlock Text="{Binding Icon, Converter={StaticResource IconConverter}}" FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <oxy:PlotView Grid.Column="1" Model="{Binding ExpenseChartModel}" Controller="{Binding HoverController}" DefaultTrackerTemplate="{StaticResource NoLinesTrackerTemplate}" Background="Transparent"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- TLAČÍTKO ADD WIDGET (Zobrazuje se přes prázdné místo namísto odstraněných / skrytých widgetů) -->
                <Grid Visibility="{Binding IsAddWidgetButtonVisible, Converter={StaticResource BoolToVisConverter}}">

                    <Button x:Name="AddWidgetBtn" Background="White" BorderBrush="#E0E0E0" BorderThickness="2" Margin="10" Height="280" Cursor="Hand" ToolTip="Přidat další widget"
                            Command="{Binding ToggleAddWidgetPopupCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="+" FontSize="64" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,-10,0,0"/>
                                        <TextBlock Text="Přidat widget" FontSize="18" FontWeight="SemiBold" Foreground="#9E9E9E" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Popup kontejner - navázán do UI výhradně vizuálně za element "AddWidgetBtn" a ovládán boolean vlastností ViewModelu -->
                    <Popup IsOpen="{Binding IsAddWidgetPopupOpen}" PlacementTarget="{Binding ElementName=AddWidgetBtn}" Placement="Center" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="3"/>
                            </Border.Effect>

                            <StackPanel Width="250">
                                <StackPanel.Resources>
                                    <Style TargetType="Button" x:Key="PopupButtonStyle">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                        <Setter Property="Padding" Value="10"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                                          Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Resources>

                                <TextBlock Text="Dostupné widgety" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                                <!-- Logika Inverse Converteru (Viditelnost tlačítka pro zobrazení panelu v menu jen ve chvíli, kdy má Property v základu false) -->
                                <Button Command="{Binding ShowWidgetCommand}" CommandParameter="Balance" 
                                        Visibility="{Binding IsBalanceVisible, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Inverted}"
                                        Style="{StaticResource PopupButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF081F;" FontSize="24" Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Vývoj zůstatku" FontWeight="SemiBold"/>
                                            <TextBlock Text="Čárový graf historie" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowWidgetCommand}" CommandParameter="CashFlow" 
                                        Visibility="{Binding IsCashFlowVisible, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Inverted}"
                                        Style="{StaticResource PopupButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0114;" FontSize="24" Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Peněžní tok" FontWeight="SemiBold"/>
                                            <TextBlock Text="Příjmy vs Výdaje" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowWidgetCommand}" CommandParameter="Income" 
                                        Visibility="{Binding IsIncomeVisible, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Inverted}"
                                        Style="{StaticResource PopupButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0134;" FontSize="24" Foreground="#8BC34A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Příjmy za období" FontWeight="SemiBold"/>
                                            <TextBlock Text="Koláčový graf příjmů" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowWidgetCommand}" CommandParameter="Expense" 
                                        Visibility="{Binding IsExpenseVisible, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Inverted}"
                                        Style="{StaticResource PopupButtonStyle}" Margin="0"> 
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" Text="&#xF0134;" FontSize="24" Foreground="#F44336" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Výdaje za období" FontWeight="SemiBold"/>
                                            <TextBlock Text="Koláčový graf výdajů" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

            </UniformGrid>
        </Grid>
    </ScrollViewer>
</UserControl>