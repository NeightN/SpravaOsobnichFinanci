<UserControl x:Class="SpravaOsobnichFinanci.Views.CategoryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpravaOsobnichFinanci.Views"
             xmlns:viewmodels="clr-namespace:SpravaOsobnichFinanci.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance Type=viewmodels:CategoryEditorViewModel}">

    <!-- DEFINICE STYLŮ (Lokální resources platné pouze pro tento UserControl) -->
    <UserControl.Resources>
        <!-- Globální přeprodej vzhledu pro všechna běžná tlačítka v tomto pohledu -->
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <!-- Vzhled pro situaci, kdy formulář není validní a tlačítko (SaveCommand.CanExecute) vrátí false -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Úprava TextBoxu pro sladění designu a přidání hover (IsMouseOver) efektů -->
        <Style x:Key="RedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B71C1C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Nadpis -->
            <RowDefinition Height="Auto"/>
            <!-- Tělo formuláře -->
            <RowDefinition Height="Auto"/>
            <!-- Odesílací tlačítka -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Detail kategorie" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Formulář obalený v bílém panelu se stínem evokující samostatnou 'kartu' -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1" HorizontalAlignment="Left" Width="450">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="5" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Sloupec pro Labely (štítky) -->
                    <ColumnDefinition Width="100"/>
                    <!-- Sloupec pro zadávací prvky -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1. ŘÁDEK | Název (Povinný s hvězdičkou) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10">
                    <TextBlock Text="Název" Foreground="#555555" FontWeight="SemiBold"/>
                    <TextBlock Text="*" Foreground="#B71C1C" FontWeight="Bold" Margin="2,0,0,0"/>
                    <TextBlock Text=":" Foreground="#555555" FontWeight="SemiBold"/>
                    <!-- Nápovědná (ToolTip) ikona z vlastního ikonovacího fontu -->
                    <TextBlock FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                               Text="&#xF02D7;" FontSize="14" Foreground="#9E9E9E" Margin="4,0,0,0" 
                               ToolTipService.InitialShowDelay="0" ToolTip="Maximální délka je 50 znaků."/>
                </StackPanel>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource RedTextBoxStyle}" Margin="0,10" MaxLength="50"/>

                <!-- 2. ŘÁDEK | Barva (Custom ListBox) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Barva:" VerticalAlignment="Top" Margin="0,15,0,0" Foreground="#555555" FontWeight="SemiBold"/>
                <ListBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableColors}" SelectedItem="{Binding ColorHex}" 
                         Margin="0,10" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <!-- Použití WrapPanelu způsobí zalomení barviček na další řádky podle dostupné šířky okna -->
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Width="300" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <!-- Vykreslení konkrétní barvy jako zaobleného kolečka -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="30" Height="30" CornerRadius="15" Margin="3" Background="{Binding}" BorderThickness="2" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Výchozí stav (netknuto) -->
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <!-- DataTrigger hlída stav ListBoxItem. Pokud na kuličku uživatel klikne (je vybrána), přidá se tmavý okraj -->
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="#333333"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <!-- Odstranění otravného modrého podsvícení standardních ListBox položek překrytím ContentPresenterem -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 3. ŘÁDEK | Ikona (Custom ListBox) -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ikona:" VerticalAlignment="Top" Margin="0,15,0,0" Foreground="#555555" FontWeight="SemiBold"/>
                <ListBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableIconKeys}" SelectedItem="{Binding IconKey}" 
                         Margin="0,10" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Width="300" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Chyták: Pozadí této ikony využívá barvu, která je zrovna vybrána v ListBoxu o úroveň výše (díky RelativeSource AncestorType=UserControl viz Binding ColorHex) -->
                            <Border Width="36" Height="36" CornerRadius="18" Margin="3"
                                    Background="{Binding DataContext.ColorHex, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    BorderThickness="2" Cursor="Hand">
                                <TextBlock Text="{Binding Converter={StaticResource IconConverter}}" 
                                           FontFamily="pack://application:,,,/Assets/Fonts/#Material Design Icons" 
                                           FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="#333333"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Akční tlačítka vázaná do ViewModelu -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="Uložit" Command="{Binding SaveCommand}" Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="Zrušit" Command="{Binding CancelCommand}" Width="100" Height="35" 
                    Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>